# =============================================
# Zinda Learn Frontend — Environment Variables
# =============================================
# Copy this file to .env and fill in real values
# VITE_ prefix is REQUIRED for Vite to expose vars to the browser bundle

# Firebase (Public — safe to expose in frontend)
VITE_FIREBASE_API_KEY=<your-firebase-api-key>
VITE_FIREBASE_AUTH_DOMAIN=<project>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<project-id>
VITE_FIREBASE_STORAGE_BUCKET=<project>.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=<sender-id>
VITE_FIREBASE_APP_ID=<app-id>

# Backend API — full URL including /api suffix
# In production: https://your-ec2-ip-or-domain.com/api
VITE_API_URL=http://localhost:5005/api

# Backend Socket.IO URL — root URL WITHOUT /api
# In production: https://your-ec2-ip-or-domain.com
VITE_SOCKET_URL=http://localhost:5005

# Cloudinary — public upload preset (safe to expose)
VITE_CLOUDINARY_CLOUD_NAME=<your-cloud-name>
VITE_CLOUDINARY_UPLOAD_PRESET=<your-upload-preset>

# NOTE: Razorpay key is served by backend API response — do NOT add it here

# Feature Flags
# Set to false to temporarily bypass OTP email verification in production
VITE_EMAIL_VERIFICATION_ENABLED=true

