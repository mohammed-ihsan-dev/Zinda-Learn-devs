# =============================================
# Zinda Learn Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in real values
# NEVER commit the real .env file to git

# Server
PORT=5005
NODE_ENV=production

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/Zinda_Learn

# JWT
JWT_SECRET=<your-long-random-secret-min-32-chars>
JWT_EXPIRE=7d

# Email (Gmail App Password)
EMAIL_SERVICE=gmail
EMAIL_USER=<your-gmail>@gmail.com
EMAIL_PASS=<gmail-app-password>
EMAIL_NAME="Zinda Learn"

# Redis (RedisLabs or Upstash)
REDIS_URL=redis://default:<password>@<host>:<port>

# Cloudinary
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# Razorpay
RAZORPAY_KEY_ID=rzp_live_<your-live-key>
RAZORPAY_KEY_SECRET=<your-live-secret>

# CORS — set to your production frontend domain
# EC2 + Nginx deployment: use your custom domain
FRONTEND_URL=https://zinda-learn.com
APP_URL=https://zinda-learn.com
SOCKET_CORS_ORIGIN=https://zinda-learn.com

# Firebase Admin SDK
# Option A: Paste full service account JSON (escaped)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
#
# Option B: Set individual fields (recommended for EC2)
FIREBASE_PROJECT_ID=<your-firebase-project-id>
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@<project>.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<key>\n-----END PRIVATE KEY-----\n"
